# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Bare binaries from building a cmd/ tool on a non-Windows box (no .exe suffix),
# e.g. `go build ./cmd/dict-foldin/` dropping ./dict-foldin in the repo root.
/dict-foldin
/prata

# Go test artifacts
*.test
*.out

# Go workspace files (machine-local)
go.work
go.work.sum

# Local audio test fixtures — personal voice recordings, not for distribution
prata-tests.m4a
prata-tests.wav

# Daemon logs (may contain diagnostics beside patient work — see AGENTS.md §11).
# The daemon writes these to %LOCALAPPDATA%\Prata\logs; this guards against a
# stray PRATA_DAEMON_LOG override or manual run dropping one in the repo.
logs/
prata-*.log

# Local run artifacts — redirected stderr captures from launching the daemon
# manually (e.g. `prata 2> prata-start.err`). Diagnostic only and may contain
# an internal backend URL; never committed.
prata-*.err

# IDE / editor
.vscode/
.idea/
# Ignore machine-local Cursor state, but keep shared project rules tracked.
.cursor/*
!.cursor/rules/
prata.code-workspace

# OS junk
.DS_Store
Thumbs.db

# Environment / secrets
.env
.env.*

# Windows shortcuts
*.lnk
